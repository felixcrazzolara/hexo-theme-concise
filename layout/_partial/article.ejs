<article class="article" itemscope itemprop="blogPost">
    <% if( post.title ) { %>
    <header class="article-header">
        <% if( view ) { %>
        <h1 itemprop="name">
            <%= post.title %>
        </h1>
        <% } else { %>
        <h1 itemprop="name">
            <a href="<%- url_for(post.path) %>"><%= post.title %></a>
        </h1>
        <% } %>
        <div class="article-meta clearfix">
            <%- partial('post/date', {icon: true, date_format: null}) %>
            <%- partial('post/tags') %>
        </div>
    </header>
    <% } %>
    <section class="article-body markdown-body">
        <%
            var content = !view && post.excerpt ? post.excerpt : post.content;
            // Fix relative paths in content to be absolute based on post path
            var postPath = post.path.replace(/index\.html$/, '');
            content = content.replace(
              /(?:src|href)="(?!(?:https?:|\/|#|data:|blob:))([^"]+)"/g,
              function(match, filename) {
                return match.replace(filename, '/' + postPath + filename);
              }
            );
        %>
        <%- content %>
        <% if( !view && post.excerpt && theme.excerpt_link ) { %>
        <p class="article-more-link">
            <a href="<%- url_for(post.path) %>#more">
                <span class="vm"><%= theme.excerpt_link %></span>
                <i class="icon-arrow-double-right vm"></i>
            </a>
        </p>
        <% } %>
    </section>
</article>
